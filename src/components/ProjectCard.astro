---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, hook, summary, tags, status } = project.data;
---

<a
  class="project-card"
  href={`/projects/${project.id}`}
  data-tags={tags.join(',')}
>
  <h3>
    {title}
    {status === 'live' && <span class="live-dot" title="Live">●</span>}
  </h3>
  <p class="hook">{hook}</p>
  <p class="summary">{summary}</p>
  <div class="tags">
    {tags.map((tag) => <span class={`tag tag-${tag}`}>{tag}</span>)}
  </div>
</a>

<style>
  .live-dot {
    color: #2c9c5e;
    font-size: 0.7em;
    vertical-align: 0.2em;
    margin-left: 0.3rem;
  }
</style>
